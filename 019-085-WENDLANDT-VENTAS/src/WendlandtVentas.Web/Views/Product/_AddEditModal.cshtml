@using WendlandtVentas.Core.Entities.Enums;
@model WendlandtVentas.Web.Models.ProductViewModels.ProductViewModel
<div class="modal-dialog" role="document">
    <form data-action="@ViewData["Action"]" id="form-product" class="modal-content">
        <div class="modal-header">
            <h4 class="modal-title" id="addModal-label">@ViewData["ModalTitle"]</h4>
            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
        <div class="modal-body">
            @Html.HiddenFor(t => t.Id)
            @Html.HiddenFor(t => t.Distinction)

            @* --- CABECERA COMÚN --- *@
            <div class="row">
                <div class="col-md-8">
                    <div class="form-group">
                        <label asp-for="Name"></label> <b class="text-danger">*</b>
                        <input asp-for="Name" class="form-control" id="Name" autofocus />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label>¿Es un Paquete?</label>
                        <div class="custom-control custom-switch custom-switch-on-success mt-1">
                            <input type="checkbox" class="custom-control-input" id="IsBundle" @(Model.IsBundle ? "checked" : "")>
                            <label class="custom-control-label" for="IsBundle">Modo Bundle</label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-group" id="sectionInventorySource" style="display:none;">
                <label asp-for="InventorySourceId">Vincular Inventario a (Producto B.C.)</label>
                <select asp-for="InventorySourceId" id="InventorySourceId" asp-items="Model.MasterProducts" class="form-control select2">
                    <option value="">-- Este es un producto maestro (B.C.) --</option>
                </select>
            </div>

            <div class="form-group">
                <label asp-for="Distinction"></label>
                <div>
                    @foreach (var distinction in Model.Distinctions)
                    {
                        var selected = distinction.Value.Equals(Model.Distinction.ToString());
                        <div class="form-check form-check-inline">
                            <input class="form-check-input radio-distinction" type="radio" name="radioDistinction" @(selected ? "checked='true'" : string.Empty) value="@distinction.Value">
                            <label class="form-check-label">@distinction.Text</label>
                        </div>
                    }
                </div>
            </div>

            <hr />

            @* --- SECCIÓN 1: PRODUCTO NORMAL (PRESENTACIONES) --- *@
            <div id="section-normal">
                <label class="font-weight-bold"><i class="fa fa-list"></i> Configuración de Presentaciones</label>
                <div class="row text-muted small font-weight-bold mb-2">
                    <div class="col-4">Presentación</div>
                    <div class="col-3">Precio MXN</div>
                    <div class="col-3">Precio USD</div>
                    <div class="col-2">Peso (kg)</div>
                </div>
                <div class="presentations border rounded p-3 bg-light" style="max-height: 300px; overflow-y: auto;">
                    @foreach (var presentation in Model.Presentations)
                    {
                        var selected = Model.PresentationsEdit?.Any(c => c.PresentationId == presentation.PresentationId) ?? false;
                        var pEdit = Model.PresentationsEdit?.FirstOrDefault(c => c.PresentationId == presentation.PresentationId);

                        <div class="row mb-2 align-items-center">
                            <div class="col-4">
                                <div class="custom-control custom-checkbox">
                                    <input type="checkbox" class="custom-control-input presentation-check" id="pres-@presentation.PresentationId" value="@presentation.PresentationId" @(selected ? "checked" : "")>
                                    <label class="custom-control-label" for="pres-@presentation.PresentationId">@presentation.PresentationName</label>
                                </div>
                            </div>
                            <div class="col-3">
                                <input type="number" class="form-control form-control-sm price-@presentation.PresentationId" @(selected ? "" : "disabled") value="@(pEdit?.Price ?? 0)">
                            </div>
                            <div class="col-3">
                                <input type="number" class="form-control form-control-sm priceUsd-@presentation.PresentationId" @(selected ? "" : "disabled") value="@(pEdit?.PriceUsd ?? 0)">
                            </div>
                            <div class="col-2">
                                <input type="number" class="form-control form-control-sm weight-@presentation.PresentationId" @(selected ? "" : "disabled") value="@(pEdit?.Weight ?? 0)">
                            </div>
                        </div>
                    }
                </div>
            </div>

            @* --- SECCIÓN 2: 12-PACK / 6-PACK (COMPOSICIÓN) --- *@
            <div id="section-bundle" style="display:none;">
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Tamaño del Pack</label> <b class="text-danger">*</b>
                            <select id="BundleTargetQty" class="form-control">
                                <option value="12">12 Unidades (12-Pack)</option>
                                <option value="6">6 Unidades (6-Pack)</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Precio Pack MXN</label> <b class="text-danger">*</b>
                            @* Agregamos el value y el step *@
                            <input type="number" id="BundlePriceMXN" class="form-control"
                                   placeholder="0.00" step="any" value="@Model.BundlePriceMXN">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Precio Pack USD</label>
                            @* Agregamos el value y el step *@
                            <input type="number" id="BundlePriceUSD" class="form-control"
                                   placeholder="0.00" step="any" value="@Model.BundlePriceUSD">
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label>Buscar Productos para el Pack</label>
                    <select id="bundleSearcher" asp-items="Model.AvailableComponents" class="form-control select2">
                        <option value="">-- Escribe el nombre de la cerveza --</option>
                    </select>
                </div>

                <table class="table table-sm table-hover border">
                    <thead class="thead-dark">
                        <tr>
                            <th>Producto</th>
                            <th width="120">Cantidad</th>
                            <th width="50"></th>
                        </tr>
                    </thead>
                    <tbody id="bundleTableBody">
                        @if (Model.Components != null && Model.Components.Any())
                        {
                            foreach (var item in Model.Components)
                            {
                                var productName = Model.AvailableComponents.FirstOrDefault(x => x.Value == item.ProductId.ToString())?.Text ?? "Producto desconocido";

                                // Agregamos la clase "bundle-row" para que el botón Guardar la vea
                                <tr class="bundle-row" data-id="@item.ProductId">
                                    <td>@productName</td>
                                    <td>
                                        @* Cambiamos "bundle-item-qty" por "comp-qty" para que el script sume el total *@
                                        <input type="number" class="form-control form-control-sm comp-qty"
                                               value="@item.Quantity" min="1">
                                    </td>
                                    <td class="text-right">
                                        @* Usamos la clase "remove-comp" que ya tienes en el script *@
                                        <button type="button" class="btn btn-sm btn-outline-danger remove-comp">
                                            <i class="fa fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                    <tfoot class="bg-light font-weight-bold">
                        <tr>
                            <td class="text-right">Total:</td>
                            <td id="currentBundleTotal">0</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
                <div id="bundle-warning" class="alert alert-warning d-none">
                    La cantidad de productos debe ser exactamente <span id="target-label">12</span>.
                </div>
            </div>

            <div class="modal-errors text-danger mt-2"></div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
            <button type="button" id="btn-save-product" class="btn btn-primary">Guardar</button>
        </div>
    </form>
</div>
<script>
    $(document).ready(function () {
        // Inicialización
        $('.select2').select2({ dropdownParent: $('#form-product'), width: '100%' });

        // --- TOGGLE BUNDLE VS NORMAL ---
        function toggleMode() {
            const isBundle = $('#IsBundle').is(':checked');
            if (isBundle) {
                $('#section-normal').hide();
                $('#section-bundle').show();
                $('#target-label').text($('#BundleTargetQty').val());
                validateBundle(); // Esto calculará el total inicial si ya hay filas
            } else {
                $('#section-normal').show();
                $('#section-bundle').hide();
            }
        }

        $('#IsBundle').on('change', toggleMode);
        $('#BundleTargetQty').on('change', function() {
            $('#target-label').text($(this).val());
            validateBundle();
        });

        // --- LÓGICA DE PRESENTACIONES NORMALES ---
        $('.presentation-check').on('change', function() {
            const id = $(this).val();
            const checked = $(this).is(':checked');
            $('.price-' + id + ', .priceUsd-' + id + ', .weight-' + id).prop('disabled', !checked);
        });

        // --- LÓGICA DE BUNDLE (TABLA) ---
        $('#bundleSearcher').on('select2:select', function(e) {
            const data = e.params.data;
            if (!data.id) return;
            if ($(`tr.bundle-row[data-id="${data.id}"]`).length > 0) return;

            const html = `
                <tr class="bundle-row" data-id="${data.id}">
                    <td>${data.text}</td>
                    <td><input type="number" class="form-control form-control-sm comp-qty" value="1" min="1"></td>
                    <td class="text-right">
                        <button type="button" class="btn btn-sm btn-danger remove-comp"><i class="fa fa-times"></i></button>
                    </td>
                </tr>`;
            $('#bundleTableBody').append(html);
            $(this).val('').trigger('change');
            validateBundle();
        });

        // Eventos delegados
        $(document).on('click', '.remove-comp', function() {
            $(this).closest('tr').remove();
            validateBundle();
        });

        $(document).on('input', '.comp-qty', validateBundle);

        // --- FUNCIÓN MAESTRA DE VALIDACIÓN ---
        function validateBundle() {
            let total = 0;
            const target = parseInt($('#BundleTargetQty').val()) || 12;

            $('.comp-qty').each(function() {
                total += parseInt($(this).val()) || 0;
            });

            $('#currentBundleTotal').text(total);
            $('#target-label').text(target);

            if (total !== target) {
                $('#currentBundleTotal').removeClass('text-success').addClass('text-danger');
                $('#bundle-warning').removeClass('d-none');
                return false;
            } else {
                $('#currentBundleTotal').removeClass('text-danger').addClass('text-success');
                $('#bundle-warning').addClass('d-none');
                return true;
            }
        }

        // --- GUARDADO ---
        $('#btn-save-product').on('click', function() {
            const isBundle = $('#IsBundle').is(':checked');
            let model = {
                Id: $('#Id').val(),
                Name: $('#Name').val(),
                IsBundle: isBundle,
                Distinction: $('.radio-distinction:checked').val(),
                Season: $('#Season').val(),
                InventorySourceId: $('#InventorySourceId').val()
            };

            if (isBundle) {
                if (!validateBundle()) {
                    alert("La cantidad del paquete no coincide con el objetivo.");
                    return;
                }
                model.BundlePriceMXN = $('#BundlePriceMXN').val();
                model.BundlePriceUSD = $('#BundlePriceUSD').val();
                model.BundleQuantityTarget = $('#BundleTargetQty').val();
                model.Components = [];
                $('.bundle-row').each(function() {
                    model.Components.push({
                        ProductId: $(this).data('id'),
                        Quantity: $(this).find('.comp-qty').val()
                    });
                });
            } else {
                model.PresentationPricesAdd = [];
                $('.presentation-check:checked').each(function() {
                    const id = $(this).val();
                    model.PresentationPricesAdd.push({
                        PresentationId: id,
                        Price: $('.price-' + id).val(),
                        PriceUsd: $('.priceUsd-' + id).val(),
                        Weight: $('.weight-' + id).val()
                    });
                });
            }

            const $btn = $(this);
            $btn.prop('disabled', true);

            $.post('/Product/' + $('#form-product').data('action'), model, function(res) {
                if (res.status === "ok") {
                    location.reload();
                } else {
                    alert(res.body);
                    $btn.prop('disabled', false);
                }
            });
        });

        // DISPARO INICIAL (Crucial para Edit)
        toggleMode();
    });
</script>