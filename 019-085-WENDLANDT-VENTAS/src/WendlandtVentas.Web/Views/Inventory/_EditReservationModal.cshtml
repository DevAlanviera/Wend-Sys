@model WendlandtVentas.Web.Models.InventoryViewModels.EditReservationViewModel

<div class="modal-dialog" role="document">
    <form asp-action="EditReservation" asp-antiforgery="true" class="modal-content forma-ajax--modal">
        <div class="modal-header">
            <h5 class="modal-title"><i class="fa fa-edit"></i> Editar apartado</h5>
            <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
        </div>
        <div class="modal-body">
            @Html.HiddenFor(m => m.Id)
            
            <div class="alert alert-info">
                <strong>Cliente:</strong> @Model.ClientName<br>
                <strong>Producto:</strong> @Model.ProductName - @Model.PresentationName<br>
                <strong>Ya usado:</strong> @Model.UsedQuantity unidades
            </div>
            
            <div class="form-group">
                <label asp-for="ReservedQuantity">Cantidad total apartada</label>
                <input asp-for="ReservedQuantity" class="form-control" type="number" min="1" />
                <span asp-validation-for="ReservedQuantity" class="text-danger"></span>
                <small>La cantidad usada ya es @Model.UsedQuantity. No puedes reducir a menos de eso.</small>
            </div>
            
            <div class="form-group">
                <label asp-for="Notes">Notas</label>
                <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
            <button type="submit" class="btn btn-primary">Guardar cambios</button>
        </div>
    </form>
</div>