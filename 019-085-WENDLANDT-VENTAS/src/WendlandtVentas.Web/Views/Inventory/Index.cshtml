@using WendlandtVentas.Web.Models.InventoryViewModels
@model FilterViewModel
@{
    ViewData["Title"] = "Inventario";
    var targetUrl = $"{Url.Action("GetData")}?{nameof(Model.ProductId)}={Model.ProductId}&{nameof(Model.PresentationId)}={Model.PresentationId}";

    // Verificamos el rol directamente en C#
    bool isAdmin = User.IsInRole("Administrator");

    // Decidimos qué ID de template usar
    string actionTemplate = isAdmin ? "#adminActionButtons" : "#userActionButtons";
}
<h4>
    @ViewData["Title"]
    <br />
    <small class="text-muted">Dashboard de productos en el inventario.</small>
</h4>
<section class="mt-3">
    <h6>Filtros</h6>
    <form>
        <div class="row">
            @{
                // Definimos los filtros de exclusión
                var excludedKeywords = new[] { "N.A.L.", "NAL.", "NAL", "FG", "F.G." };

                // Filtramos las listas una sola vez para usarlas abajo
                var filteredProducts = Model.Products
                .Where(p => !excludedKeywords.Any(key => p.Text.Contains(key, StringComparison.OrdinalIgnoreCase)));

                var filteredPresentations = Model.Presentations
                .Where(p => !excludedKeywords.Any(key => p.Text.Contains(key, StringComparison.OrdinalIgnoreCase)));
            }

            <div class="col-3">
                <div class="form-group">
                    <label asp-for="ProductId"></label>
                    @Html.DropDownListFor(m => m.ProductId, filteredProducts, "Todos", new { @class = "form-control" })
                </div>
            </div>

            <div class="col-3">
                <div class="form-group">
                    <label asp-for="PresentationId"></label>
                    @Html.DropDownListFor(m => m.PresentationId, filteredPresentations, "Todas", new { @class = "form-control" })
                </div>
            </div>

            <div class="col-3 pt-3">
                <button type="submit" class="btn btn-primary mt-3">Buscar</button>
                    @* Botón de Descargar *@
                <a asp-action="DescargarReportePlantilla"
                   class="btn btn-success mt-3"
                   title="Descargar Inventario">
                    <i class="fa fa-download"></i>
                </a>
                <a asp-action="Index" class="btn btn-secondary mt-3">Limpiar</a>
            </div>
        </div>
    </form>
</section>
@{
    // Cambiamos el objeto para que coincida con lo que Syncfusion espera
    var ordenInventario = new List<object> {
        new { field = "SortPriority", direction = "Ascending" }, // 1 para B.C., 2 para el resto
        new { field = "name", direction = "Ascending" }
    };
}
<div class="datatable-container">
    <ejs-grid id="Grid" class="datatable" dataBound="onDataBound" detailTemplate="#batchDetailTemplate" locale="es-MX" allowGrouping="true" allowPaging="true" allowSorting="true" toolbar="@(new List<string>() {"Search"})">

        @* Pasamos la lista genérica. El Grid es lo suficientemente inteligente para entenderla *@
        <e-grid-sortSettings columns="ordenInventario"></e-grid-sortSettings>

        <e-grid-pagesettings pageCount="25"></e-grid-pagesettings>
        <e-grid-aggregates>
            <e-grid-aggregate>
                <e-aggregate-columns>
                    <e-aggregate-column field="liters" type="Sum" groupCaptionTemplate="${Sum}" format="N2"></e-aggregate-column>
                </e-aggregate-columns>
            </e-grid-aggregate>
        </e-grid-aggregates>
        <e-data-manager url="@targetUrl" adaptor="UrlAdaptor"></e-data-manager>
        <e-grid-searchsettings fields="@(new[] { "Name", "Presentation" })"></e-grid-searchsettings>
        <e-grid-groupsettings showGroupedColumn="false" showDropArea="false" columns="@(new string[] {"name"})"></e-grid-groupsettings>
        <e-grid-columns>
            <e-grid-column field="SortPriority" visible="false"></e-grid-column>Y

            <e-grid-column field="name" headerText="Nombre" width="300"></e-grid-column>
            <e-grid-column field="presentation" headerText="Presentación" width="200"></e-grid-column>
            <e-grid-column field="liters" headerText="Litros" format="N2" width="100" textAlign="Right" headerTextAlign="Left"></e-grid-column>
            <e-grid-column headerText="En existencia" width="200" template="#movements" textAlign="Center"></e-grid-column>
            <e-grid-column width="130" template="@actionTemplate" textAlign="Right"></e-grid-column>
        </e-grid-columns>
    </ejs-grid>
</div>

@section Modals{
    <div class="modal modal-focus-first" id="inModal" tabindex="-1" role="dialog" aria-labelledby="inModal-label" data-url="@Url.Action("In")">
    </div>
    <div class="modal" id="outModal" tabindex="-1" role="dialog" aria-labelledby="outModal-label" data-url="@Url.Action("Out")">
    </div>
    <div class="modal" id="adjustmentModal" tabindex="-1" role="dialog" aria-labelledby="adjustmentModal-label" data-url="@Url.Action("Adjustment")">
    </div>
    <div class="modal modal-focus-first" id="reservationModal" tabindex="-1" role="dialog" aria-labelledby="reservationModal-label" data-url="@Url.Action("CreateReservation")">
    </div>
    <div class="modal modal-focus-first" id="editReservationModal" tabindex="-1" role="dialog" aria-labelledby="editReservationModal-label" data-url="@Url.Action("EditReservation")">
    </div>
    <div class="modal modal-focus-first" id="deleteModal" tabindex="-1" role="dialog" aria-labelledby="deleteModal-label" data-url="@Url.Action("DeleteReservation")">
    </div>
}

@section Scripts{
    <script>
        // Funciones auxiliares
        function getTotalReserved(reservations) {
            if (!reservations || reservations.length === 0) return 0;
            var total = 0;
            for (var i = 0; i < reservations.length; i++) {
                total += reservations[i].reservedQuantity - reservations[i].usedQuantity;
            }
            return total;
        }

        // Función corregida para cargar reservaciones (con botón de Editar)
function loadReservations(productId, rowData) {
    var tbody = $('#reservationsBody_' + productId);
    if (tbody.length) {
        if (rowData && rowData.reservations && rowData.reservations.length > 0) {
            var html = '';
            for (var i = 0; i < rowData.reservations.length; i++) {
                var r = rowData.reservations[i];
                html += '<tr>' +
                    '<td>' + (r.clientName || 'Cliente') + '</td>' +
                    '<td>' + r.reservedQuantity + '</td>' +
                    '<td>' + r.usedQuantity + '</td>' +
                    '<td><strong class="text-primary">' + r.availableQuantity + '</strong></td>' +
                    '<td>' + (r.expirationDate || 'N/A') + '</td>' +
                    '<td><span class="badge ' + (r.statusColor || 'badge-success') + '">' + (r.statusText || 'Activo') + '</span></td>' +
                    // Dentro de loadReservations, donde construyes el HTML, reemplaza el <td> de acciones por este:

                    '<td class="text-right">' +
                    // 🔥 NUEVO BOTÓN DE EDITAR: Clase y data-attributes específicos 🔥
                    '<button type="button" data-reservation-id="' + r.id + '" title="Editar apartado" class="tip btn btn-sm btn-outline-primary btn-edit-reservation-modal">' +
                    '<i class="fa fa-fw fa-edit"></i>' +
                    '</button> ' +
                    // BOTÓN DE CANCELAR
                    // BOTÓN DE CANCELAR (Ahora usa el modal compartido)
                    '<a href="#deleteModal" data-id="' + r.id + '" title="Cancelar apartado" class="tip btn btn-sm btn-outline-danger btn-modal-action">' +
                    '<i class="fa fa-fw fa-trash"></i>' +
                    '</a>' +
                    '</td>' +
                    '</tr>';
            }
            tbody.html(html);
        } else {
            tbody.html('<tr><td colspan="7" class="text-center text-muted">No hay apartados activos para este producto</td></tr>');
        }
    }
}

        
        function onDataBound(args) {
            var gridData = this.getCurrentViewRecords();
            gridData.forEach(function(row) {
            });
        }
    </script>

    <script>
        $(document).ready(function() {
            // Manejador para el botón de modal apartado
            $(document).on('click', '.btn-reservation-modal', function(e) {
                e.preventDefault();
                e.stopPropagation();
                
                var productPresentationId = $(this).data('product-presentation-id');
                var $modal = $('#reservationModal');
                var url = $modal.data('url');
                
                if (!productPresentationId) {
                    console.error('No se encontró product-presentation-id');
                    return;
                }
                
                $.get(url, { productPresentationId: productPresentationId }, function(data) {
                    $modal.html(data);
                    $modal.modal('show');
                }).fail(function(error) {
                    alert('Error al cargar el formulario de apartado');
                });
            });

            // Manejador genérico de botones modales
           $(document).on('click', '.btn-modal-action', function (e) {
                // 🔥 ESTO ES VITAL PARA QUE NO FALLE EL ENLACE 🔥
                e.preventDefault(); 
                e.stopPropagation();  
                
                var $btn = $(this);
                var modalId = $btn.attr('href');
                var baseUrl = $(modalId).data('url');
                var id = $btn.attr('data-id');
                var bId = $btn.attr('data-batch-id'); 

                var urlConParametros = baseUrl + "?id=" + id;

                 // 🔥 LOG para depurar
                console.log("Modal ID:", modalId);
                console.log("Base URL:", baseUrl);
                console.log("ID:", id);
                console.log("URL final:", urlConParametros);

                console.log('URL llamada:', '/Inventory/GetAvailableStockForClient?clientId=' + clientId + '&productPresentationId=' + productId);

                if (bId && bId !== "undefined" && bId !== "") {
                    urlConParametros += "&batchId=" + bId;
                }

                $(modalId).load(urlConParametros, function () {
                    $(modalId).modal('show');
                });
            });

            // Manejador de formularios ajax
            $(document).off('submit', '.forma-ajax--modal').on('submit', '.forma-ajax--modal', function (e) {
                e.preventDefault(); 
                e.stopImmediatePropagation();

                var $form = $(this);
                var $modal = $form.closest('.modal');
                var $btn = $form.find('button[type="submit"]');

                $btn.attr('disabled', 'disabled').html('<i class="fa fa-spinner fa-spin"></i> Guardando...');

                $.ajax({
                    url: $form.attr('action'),
                    type: 'POST',
                    data: $form.serialize(),
                    success: function (response) {
                        if (response.status === "ok") {
                            $modal.modal('hide');
                            var gridObj = document.getElementById("Grid").ej2_instances[0];
                            if (gridObj) {
                                gridObj.refresh();
                            }
                        } else {
                            alert("Error: " + response.body);
                            $btn.removeAttr('disabled').text('Guardar');
                        }
                    },
                    error: function (xhr) {
                        alert("Ocurrió un error al procesar la solicitud.");
                        $btn.removeAttr('disabled').text('Guardar');
                    }
                });
                return false; 
            });

            // Manejador específico para EDITAR Reservación
            $(document).on('click', '.btn-edit-reservation-modal', function(e) {
                e.preventDefault();
                e.stopPropagation();
                
                var reservationId = $(this).data('reservation-id');
                var $modal = $('#editReservationModal');
                var url = $modal.data('url');
                
                if (!reservationId) {
                    console.error('No se encontró reservation-id');
                    return;
                }
                
                // 🔥 Aquí enviamos explícitamente reservationId para que C# no se caiga 🔥
                $.get(url, { reservationId: reservationId }, function(data) {
                    $modal.html(data);
                    $modal.modal('show');
                }).fail(function(xhr) {
                    console.error(xhr.responseText);
                    alert('Error al cargar el formulario de edición.');
                });
            });

            // Evento cuando se expande un detalle del grid de Syncfusion
            var grid = document.getElementById("Grid").ej2_instances[0];
            if (grid) {
                grid.detailDataBound = function(args) {
                    var rowData = args.data;
                    if (rowData && rowData.id) {
                        setTimeout(function() {
                            // Pasamos args.data completo en lugar de recalcular el índice, es mucho más seguro.
                            loadReservations(rowData.id, rowData);
                        }, 50);
                    }
                };
            }
        });
    </script>

    <!-- TUS TEMPLATES ORIGINALES (Mantenidos intactos) -->
    <script id="adminActionButtons" type="text/x-template">
        <div>
            <a href="#inModal" data-id="${id}" title="Agregar entrada" class="tip btn btn-sm btn-light mr-2 btn-modal-action"><i class="fa fa-fw fa-inbox-in text-success"></i></a>
            <a href="#outModal" data-id="${id}" title="Agregar salida" class="tip btn btn-sm btn-light mr-2 btn-modal-action"><i class="fa fa-fw fa-inbox-out text-danger"></i></a>
            <a href="#adjustmentModal" data-id="${id}" title="Realizar ajuste" class="tip btn btn-sm btn-light mr-2 btn-modal-action"><i class="fa fa-fw fa-pen"></i></a>
            <a href="#reservationModal" data-id="${id}" title="Apartar inventario" class="tip btn btn-sm btn-light mr-2 btn-modal-action"><i class="fa fa-fw fa-tag text-info"></i></a>
        </div>
    </script>

    <script id="userActionButtons" type="text/x-template">
        <div>
            <a href="#inModal" data-id="${id}" title="Agregar entrada" class="tip btn btn-sm btn-light mr-2 btn-modal-action"><i class="fa fa-fw fa-inbox-in text-success"></i></a>
        </div>
    </script>

    <script id="movements" type="text/x-template">
        <div>
            <a href="/Movement?productPresentationId=${id}" title="Ver movimientos" class="tip btn btn-light" style="width:70px">${stock}</a>
        </div>
    </script>

    <script id="batchDetailTemplate" type="text/x-template">
        <div class="p-3 bg-light border-rounded">
            <!-- Lotes -->
            <h6><i class="fa fa-boxes mr-2"></i>Desglose de Lotes Disponibles</h6>
            <table class="table table-sm table-bordered">
                <thead><tr><th>Lote</th><th>Existencia</th><th>Caducidad</th><th>Estado</th><th>Acciones</th></tr></thead>
                <tbody>
                    ${if(batches && batches.length)}
                        ${for(batch of batches)}
                            <tr><td>${batch.batchNumber}</td><td>${batch.currentQuantity}</td><td>${batch.expiryDateFormatted}</td>
                            <td><span class="badge ${batch.statusColor}">${batch.statusText}</span></td>
                            <td><a href="#inModal" data-id="${id}" data-batch-id="${batch.id}" class="btn btn-sm btn-outline-success btn-modal-action"><i class="fa fa-inbox-in"></i></a></td></tr>
                        ${/for}
                    ${else}<tr><td colspan="5">No hay lotes</td></tr>${/if}
                </tbody>
            </table>

            <!-- Apartados -->
            <h6 class="mt-3"><i class="fa fa-tag mr-2"></i>Apartados por Cliente</h6>
            <table class="table table-sm table-bordered">
                <thead><tr><th>Cliente</th><th>Apartado</th><th>Usado</th><th>Disponible</th><th>Vence</th><th>Estado</th><th>Acciones</th></tr></thead>
                <tbody id="reservationsBody_${id}"><tr><td colspan="7">Cargando...</td></tr></tbody>
            </table>
            
      
        </div>
    </script>
}



