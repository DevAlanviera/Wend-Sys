@model WendlandtVentas.Web.Models.InventoryViewModels.InOutViewModel
<div class="modal-dialog" role="document">
    <form asp-action="@ViewData["Action"]" asp-antiforgery="true" class="modal-content forma-ajax--modal">
        <div class="modal-header">
            <h4 class="modal-title" id="addModal-label">@ViewData["ModalTitle"]</h4>
            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
        <div class="modal-body">
            @Html.HiddenFor(t => t.ProductPresentationId)
            @Html.HiddenFor(m => m.BatchId)
            <p class="text-muted small">
                Campos marcados con asterisco son requeridos.
            </p>

            @* --- SECCIÓN DE LOTE (Diferenciada) --- *@
            @if (Model.IsAdjustment || (string)ViewData["Action"] == "Out")
            {
                <div class="form-group">
                    <label>Seleccionar Lote</label> <b class="text-danger">*</b>
                    @* Usamos el operador null-coalescing ?? para asegurar una lista vacía si viene nulo *@
                    @Html.DropDownListFor(m => m.BatchId,
                    Model.AvailableBatches ?? new List<SelectListItem>(),
                                "Seleccione un lote disponible",
                                new { @class = "form-control", id = "batchSelector" })
                <span asp-validation-for="BatchId" class="text-danger"></span>
            </div>
            <!-- 🔥 AGREGAR: Campo para mostrar el número de lote seleccionado -->
            <div class="form-group" id="batchNumberContainer" style="display:none;">
                <label>Número de Lote</label>
                <input type="text" id="displayBatchNumber" class="form-control" readonly />
            </div>

            <input type="hidden" name="BatchNumber" value="N/A" />
            }
            else
            {
                @* Si el BatchId tiene valor, es una entrada a lote existente *@
                @if (Model.BatchId.HasValue)
                {
                    <div class="form-group">
                        <label asp-for="BatchNumber">Número de Lote (Existente)</label>
                        @* Lo ponemos readonly para que no lo editen por error *@
                        <input asp-for="BatchNumber" class="form-control" readonly />
                        <input type="hidden" asp-for="BatchId" />
                        <span asp-validation-for="BatchNumber" class="text-danger"></span>
                        <small class="text-info">Usted está agregando stock a este lote específico.</small>
                    </div>
                }
                else
                {
                    <div class="form-group">
                        <label asp-for="BatchNumber">Número de Lote</label> <b class="text-danger">*</b>
                        <input asp-for="BatchNumber" class="form-control" id="inputBatchNumber" placeholder="Ej. L-2024-001" />
                        <span asp-validation-for="BatchNumber" class="text-danger"></span>
                    </div>
                }
            }

            @* --- SECCIÓN DE CANTIDAD Y FECHA --- *@
            <div class="form-row">
                <div class="form-group col-md-6">
                    <label asp-for="Quantity">Cantidad</label> <b class="text-danger">*</b>
                    <input asp-for="Quantity" class="form-control" id="inputQuantity" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>

                @* SOLO MOSTRAR FECHA SI NO ES SALIDA *@
                @if ((string)ViewData["Action"] != "Out")
                {
                    @if (Model.BatchId.HasValue)
                    {
                        <div class="form-group">
                            <label asp-for="ExpiryDate">Fecha de Caducidad</label>
                            @* La mostramos readonly para que el usuario sepa qué lote está afectando *@
                            <input type="text" class="form-control" value="@Model.ExpiryDate?.ToString("dd/MM/yyyy")" readonly />
                            @* Enviamos la fecha oculta para que el modelo sea válido en el POST *@
                            <input type="hidden" asp-for="ExpiryDate" />
                        </div>
                    }
                    else
                    {
                        <div class="form-group col-md-6">
                            <label asp-for="ExpiryDate">Fecha de Caducidad</label> <b class="text-danger">*</b>
                            <input asp-for="ExpiryDate" type="text" class="form-control date-picker-lotes" id="inputExpiry" autocomplete="off" />
                            <span asp-validation-for="ExpiryDate" class="text-danger"></span>
                        </div>
                    }
                    
                }

                
            </div>

            @* --- COMENTARIOS --- *@
            <div class="form-group">
                <label asp-for="Comment">Comentario / Motivo</label>
                <textarea asp-for="Comment" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Comment" class="text-danger"></span>
            </div>

            <div class="modal-errores text-danger"></div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
            <button type="submit" class="btn btn-primary">Guardar</button>
        </div>
    </form>
</div>

<script>
    $(function () {
        // Inicializar selector de fecha
        $(".date-picker-lotes").datepicker({
            autoclose: true,
            format: 'dd/mm/yyyy',
            theme: 'bootstrap4'
        });

        // Lógica de autocompletado solo para Ajuste o Salida
            $('#batchSelector').on('change', function() {
        var batchId = $(this).val();
        if (batchId) {
            // 🔥 IMPORTANTE: Actualizar el campo oculto BatchId
            $('input[name="BatchId"]').val(batchId);
            // O si tiene id específico: $('#BatchId').val(batchId);

            console.log('BatchId seleccionado:', batchId);
            console.log('BatchId oculto actualizado:', $('input[name="BatchId"]').val());

            $.get('/Inventory/GetBatchDetails/' + batchId, function(data) {
                console.log('Datos del lote:', data);

                @if (Model.IsAdjustment)
                {
                        <text>$('#inputQuantity').val(data.currentQuantity);</text>
                }
                else
                {
                        <text>$('#inputQuantity').val('');</text>
                        <text>$('#inputQuantity').attr('placeholder', 'Cantidad a retirar (Stock: ' + data.currentQuantity + ')');</text>
                }

                if(data.expiryDate) {
                    var date = new Date(data.expiryDate);
                    $('#inputExpiry').datepicker('setDate', date);
                }
            });
        } else {
            // Limpiar cuando no hay selección
            $('input[name="BatchId"]').val('');
            $('#inputQuantity').val('');
            $('#inputExpiry').val('');
        }
    });
    });
</script>