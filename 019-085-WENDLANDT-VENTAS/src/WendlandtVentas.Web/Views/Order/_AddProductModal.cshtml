@model WendlandtVentas.Web.Models.OrderViewModels.OrderAddProductViewModel
@using WendlandtVentas.Core.Entities.Enums
<div class="modal-dialog" role="document">
    <form id="form-addProduct" class="modal-content">
        <div class="modal-header">
            <h4 class="modal-title" id="addModal-label">@ViewData["ModalTitle"]</h4>
            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
        <div class="modal-body">
            <p class="text-muted">
                Todos los campos son requeridos.
            </p>
            <div class="form-group">
                <label asp-for="ProductPresentationId"></label>
                @Html.DropDownListFor(m => m.ProductPresentationId, Model.ProductsPresentations, "Seleccionar producto", new { @class = "form-control select2", @style = "width:100%;" })
                <span asp-validation-for="ProductPresentationId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Quantity"></label>
                <input asp-for="Quantity" class="form-control" min="0" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>
            @if (Model.IsAuthorized(User))
            {
                <div class="form-group">
                    <label asp-for="Price"></label>
                    <input asp-for="Price" id="Price" class="form-control" min="0" step="0.01" type="number" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
            }
            else
            {
                <div class="form-group">
                    <label asp-for="Price"></label>
                    <input asp-for="Price" class="form-control" min="0" step="0.01" type="number" disabled />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
            }
             @if (Model.IsAuthorized(User))
            {
            <div class="form-check form-check-inline">
                <label asp-for="IsPresent"></label>
                <input asp-for="IsPresent" class="form-check-input ml-1 mb-1" />
                </div>
            }
            else
            {
                
            }
            <div class="modal-errors text-danger"></div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
            <button type="submit" class="btn btn-primary">Agregar</button>
        </div>
    </form>
</div>

<script>
    $(document).ready(function () {
        let stockDisponible = 0;

    function esTipoDevolucion() {
        // Obtenemos el valor del radio button seleccionado
        var tipoSeleccionado = $("input[name='IsInvoice']:checked").val();

        // Comparamos contra el NOMBRE del Enum como string
        // Usamos ToString() para que Razor pinte "Return" en lugar de un número
        var valorReturnEsperado = "@WendlandtVentas.Core.Entities.Enums.OrderType.Return.ToString()";

        var esDev = (tipoSeleccionado === valorReturnEsperado);

        console.log("Tipo Seleccionado:", tipoSeleccionado, "| Esperado:", valorReturnEsperado, "| Resultado:", esDev);

        return esDev;
    }

        $(document).on("change", "#ProductPresentationId", function () {
            var combinedValue = $(this).val();
            if (!combinedValue) {
                $(".modal-errors").empty();
                stockDisponible = 0;
                return;
            }

            var productId = combinedValue.split("-")[0];
            var currencyType = $("#CurrencyType").val();

            $.get("/Order/GetProductStock", { id: productId })
            .done(function (response) {
                // CORRECCIÓN: Accedemos a response.stock
                stockDisponible = response.stock;

                if (esTipoDevolucion()) {
                    $(".modal-errors").html(
                        '<div class="alert alert-info py-1">' +
                        'Modo Devolución: Stock actual <b>' + stockDisponible + '</b> (se sumará el reingreso).' +
                        '</div>'
                    );
                } else {
                    if (stockDisponible <= 0) {
                        $(".modal-errors").html('<div class="alert alert-danger py-1">⚠️ Sin existencias disponibles en lotes.</div>');
                    } else {
                        $(".modal-errors").html('<div class="alert alert-info py-1">Stock disponible: <b>' + stockDisponible + '</b></div>');
                    }
                }
            });

            $.get("/Order/GetProductPrice", { currencyType: currencyType, id: productId })
                .done(function (price) {
                    $("#Price").val(price);
                });
        });

        $("#form-addProduct").on("submit", function (e) {
            var cantidadSolicitada = parseInt($("#Quantity").val());

            if (isNaN(cantidadSolicitada) || cantidadSolicitada <= 0) {
                e.preventDefault();
                $(".modal-errors").html('<div class="alert alert-warning py-1">Ingresa una cantidad válida.</div>');
                return false;
            }

            // CORRECCIÓN: Si es devolución, permitimos cualquier cantidad (porque es reingreso)
            if (esTipoDevolucion()) {
                return true;
            }

            // Si es venta, validamos contra el stock
            if (cantidadSolicitada > stockDisponible) {
                e.preventDefault();
                $(".modal-errors").html(
                    '<div class="alert alert-warning py-1">' +
                    '<strong>Stock insuficiente:</strong> No puedes vender ' + cantidadSolicitada +
                    '. El máximo disponible es ' + stockDisponible + '.' +
                    '</div>'
                );
                return false;
            }
        });
    });
</script>

